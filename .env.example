# Application
NODE_ENV=development
APP_NAME=Inbox Flow
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
API_PORT=3001

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# Optional: Supabase Queues (pgmq) — only if RUN_WORKERS=true
# After enabling: npm run db:setup-queues -w @inboxflow/api

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=change-me-32-byte-hex-encryption-key!!

# Email — SMTP_HOST=json logs transactional mail (password reset, etc.) to the API console in dev.
# Campaign SMTP profiles are added in the app (Settings → SMTP Manager), not from env.
SMTP_HOST=json
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@inboxflow.io
EMAIL_FROM_ADDRESS=noreply@inboxflow.io
EMAIL_FROM_NAME=Inbox Flow

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=inboxflow
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/inboxflow

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Email sending defaults
DEFAULT_SEND_RATE=14
MAX_RETRY_ATTEMPTS=3
BATCH_SIZE=100

# CORS
CORS_ORIGIN=http://localhost:5173

# --- Supabase Edge Functions (Nexlogs-style, no Render for email) ---
# Frontend flags (apps/web — also set in Vercel):
# VITE_USE_EDGE_FUNCTIONS=true
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# Edge Function secrets (set via supabase secrets set — NOT in .env for production):
# JWT_ACCESS_SECRET, ENCRYPTION_KEY, SMTP_*, APP_URL — see docs/DEPLOYMENT_SUPABASE.md

# Webhook base URL (publicly reachable for provider webhooks)
WEBHOOK_BASE_URL=http://localhost:3001
# Shared secret required on provider webhooks (header x-webhook-secret or ?secret=)
WEBHOOK_SECRET=change-me-webhook-secret-min-16-chars

# Public self-serve signup (keep false in production)
ALLOW_PUBLIC_REGISTER=false

# Admin account (used by db:seed — set before running npm run db:seed)
SEED_ADMIN_EMAIL=admin@inboxflow.com
SEED_ADMIN_PASSWORD=change-me-strong-password

# API Swagger UI (/docs). Defaults on in development, off in production.
# ENABLE_API_DOCS=true

# Force Secure cookies (defaults to true in production)
# COOKIE_SECURE=false
